# Required ----------------------------------------------------------------

# Postgres connection string. On Vercel this is auto-injected by the Neon
# integration; locally, paste the Neon (or any Postgres) URL here.
DATABASE_URL=postgres://user:pass@host/db

# Random 32+ character string used to sign session cookies.
SESSION_SECRET=change-me

# Resend API key + verified from address.
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL="SONSIEL Mentorship Hub <noreply@sonsiel.org>"

# Public URL of the deployment (no trailing slash). Used in email links.
APP_URL=https://mentorship.sonsiel.org

# Phase 2 (real-time) -----------------------------------------------------
# ABLY_API_KEY=

# Phase 3 (file uploads) --------------------------------------------------
# BLOB_READ_WRITE_TOKEN=
